# ==========================================
# Archivos del Sistema Operativo (Mac/Windows)
# ==========================================
.DS_Store
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db

# ==========================================
# Carpetas de Xilinx ISE
# ==========================================
iseconfig/

# ==========================================
# Ignore all files by default
# ==========================================
*

# ==========================================
# Only keep these file types
# ==========================================
!.gitignore
!*.xise
!*.vhd
!*.ucf
!*.md

# ==========================================
# Python
# ==========================================
!*.py
!requirements.txt

# ==========================================
# Allow directories (so git can traverse them)
# ==========================================
!*/

# Exclude the virtual environment directory (must come after !*/)
.venv/

# ==========================================
# Ignore CLAUDE.md
# ==========================================
CLAUDE.md
